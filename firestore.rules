rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : get(/databases/$(database)/documents/users/$(
            get(/databases/$(database)/documents/qrUsers/$(request.auth.uid)).data.mainUid
          )).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isStaffOrAdmin() {
      return isSignedIn() && (getUserData().role == 'staff' || getUserData().role == 'admin');
    }

    function isAdmin() {
      return hasRole('admin');
    }

    // The professor's Google email is the only account allowed to self-switch roles.
    function isProfessor() {
      return isSignedIn() && request.auth.token.email == 'jcesperanza@neu.edu.ph';
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        isStaffOrAdmin() ||
        (exists(/databases/$(database)/documents/qrUsers/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/qrUsers/$(request.auth.uid)).data.mainUid == userId)
      );

      // Normal create: own UID
      allow create: if isSignedIn() && request.auth.uid == userId;

      allow update: if isSignedIn() && (
        // Regular user can update own doc — but cannot change role
        (
          request.auth.uid == userId &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
        ) ||
        // Professor can self-switch role between 'student' and 'admin' only
        (
          request.auth.uid == userId &&
          isProfessor() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role']) &&
          request.resource.data.role in ['student', 'admin']
        ) ||
        // Admin can update non-admin users (but only to staff or student)
        (
          isAdmin() &&
          request.auth.uid != userId &&
          resource.data.role != 'admin' &&
          (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) ||
           request.resource.data.role in ['staff', 'student'])
        )
      );

      allow delete: if isAdmin();
    }

    // ── QR Users ──────────────────────────────────────────────────────────────
    match /qrUsers/{qrUid} {
      allow read:           if isSignedIn() && request.auth.uid == qrUid;
      allow create:         if isSignedIn() && request.auth.uid == qrUid;
      allow update, delete: if false;
    }

    // ── Role Change Audit Log (legacy) ────────────────────────────────────────
    match /roleChangeLogs/{logId} {
      allow read:           if isAdmin();
      allow create:         if isAdmin();
      allow update, delete: if false;
    }

    // ── Admin Audit Log ───────────────────────────────────────────────────────
    match /adminAuditLogs/{logId} {
      allow read:           if isAdmin();
      allow create:         if isAdmin();
      allow update, delete: if false;
    }

    // ── Delete Requests ───────────────────────────────────────────────────────
    match /deleteRequests/{reqId} {
      allow create: if isStaffOrAdmin();
      allow read:   if isAdmin() || (isStaffOrAdmin() && resource.data.requestedBy == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Books ─────────────────────────────────────────────────────────────────
    match /books/{bookId} {
      allow read:          if isSignedIn();
      allow create, update: if isStaffOrAdmin();
      allow delete:        if isStaffOrAdmin();
    }

    // ── Borrows ───────────────────────────────────────────────────────────────
    match /borrows/{borrowId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isStaffOrAdmin());
      allow create: if isSignedIn() && (
        isStaffOrAdmin() ||
        (request.resource.data.userId == request.auth.uid && request.resource.data.status == 'pending')
      );
      allow update: if isStaffOrAdmin() || (
        isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        resource.data.status == 'pending' &&
        request.resource.data.status == 'cancelled' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
      );
      allow delete: if isAdmin();
    }

    // ── Logger ────────────────────────────────────────────────────────────────
    match /logger/{logId} {
      // Professor (admin role) can read all for statistics
      allow read: if isSignedIn() && (
        resource.data.uid == request.auth.uid ||
        isStaffOrAdmin()
      );
      allow create: if isSignedIn() && (
        request.resource.data.uid == request.auth.uid || isStaffOrAdmin()
      );
      allow update: if isSignedIn() && (
        resource.data.uid == request.auth.uid || isStaffOrAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── Penalties ─────────────────────────────────────────────────────────────
    match /penalties/{penaltyId} {
      allow read:  if isSignedIn() && (resource.data.userId == request.auth.uid || isStaffOrAdmin());
      allow write: if isStaffOrAdmin();
    }

    // ── Email queue ───────────────────────────────────────────────────────────
    match /emailQueue/{docId} {
      allow read:          if isStaffOrAdmin();
      allow create:        if isStaffOrAdmin();
      allow update, delete: if isAdmin();
    }

    // ── Book Activity Log ─────────────────────────────────────────────────────
    match /bookLogs/{logId} {
      allow read:          if isStaffOrAdmin();
      allow create:        if isStaffOrAdmin();
      allow update, delete: if false;
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.toUid == request.auth.uid || isStaffOrAdmin());
      allow create: if isStaffOrAdmin();
      allow update: if isStaffOrAdmin() || (
        isSignedIn() &&
        resource.data.toUid == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['acknowledged', 'acknowledgedAt'])
      );
      allow delete: if isAdmin();
    }
  }
}
