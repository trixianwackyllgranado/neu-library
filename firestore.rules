rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {"role": "guest"};
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isStaffOrAdmin() {
      return isSignedIn() && (getUserData().role == 'staff' || getUserData().role == 'admin');
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isNEUEmail() {
      return isSignedIn() &&
             request.auth.token.email != null &&
             request.auth.token.email.matches('.*@neu[.]edu[.]ph$');
    }

    // Users collection
    match /users/{userId} {
      allow get: if isSignedIn() && (
        request.auth.uid == userId ||
        isStaffOrAdmin()
      );
      allow list: if isSignedIn();

      // Only NEU emails can create their own profile (Google sign-in sets this)
      allow create: if isSignedIn() &&
                       request.auth.uid == userId &&
                       isNEUEmail();

      allow update: if isSignedIn() && (
        // Own doc — no role changes
        (request.auth.uid == userId &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) ||
        // Admin can change roles (not to admin)
        (isAdmin() &&
         request.auth.uid != userId &&
         resource.data.role != 'admin' &&
         (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) ||
          request.resource.data.role in ['staff', 'visitor']))
      );

      allow delete: if isAdmin();
    }

    // Logger — visitors and staff/admin can read own, staff/admin can read all
    match /logger/{logId} {
      allow read: if isSignedIn() && (
        resource.data.uid == request.auth.uid ||
        isStaffOrAdmin()
      );
      allow create: if isSignedIn() && (
        request.resource.data.uid == request.auth.uid || isStaffOrAdmin()
      );
      allow update: if isSignedIn() && (
        resource.data.uid == request.auth.uid || isStaffOrAdmin()
      );
      allow delete: if isAdmin();
    }

    // Admin Audit Log — immutable
    match /adminAuditLogs/{logId} {
      allow read:           if isAdmin();
      allow create:         if isAdmin();
      allow update, delete: if false;
    }

    // Delete Requests
    match /deleteRequests/{reqId} {
      allow create: if isStaffOrAdmin();
      allow read:   if isAdmin() || (isStaffOrAdmin() && resource.data.requestedBy == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.toUid == request.auth.uid || isStaffOrAdmin());
      allow create: if isStaffOrAdmin();
      allow update: if isStaffOrAdmin() || (
        isSignedIn() &&
        resource.data.toUid == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['acknowledged', 'acknowledgedAt'])
      );
      allow delete: if isAdmin();
    }
  }
}
