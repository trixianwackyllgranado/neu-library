rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      // Normal accounts have users/{uid} directly.
      // QR ghost accounts don't — resolve via qrUsers/{uid}.mainUid.
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : get(/databases/$(database)/documents/users/$(
            get(/databases/$(database)/documents/qrUsers/$(request.auth.uid)).data.mainUid
          )).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isStaffOrAdmin() {
      return isSignedIn() && (getUserData().role == 'staff' || getUserData().role == 'admin');
    }

    function isAdmin() {
      return hasRole('admin');
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        isStaffOrAdmin() ||
        (exists(/databases/$(database)/documents/qrUsers/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/qrUsers/$(request.auth.uid)).data.mainUid == userId)
      );
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        (
          request.auth.uid == userId &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
        ) ||
        (
          isAdmin() &&
          request.auth.uid != userId &&
          resource.data.role != 'admin' &&
          (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) ||
           request.resource.data.role in ['staff', 'student'])
        )
      );
      allow delete: if isAdmin();
    }

    // ── QR Users (ghost Firebase Auth account → main UID mapping) ─────────────
    match /qrUsers/{qrUid} {
      allow read:   if isSignedIn() && request.auth.uid == qrUid;
      allow create: if isSignedIn() && request.auth.uid == qrUid;
      allow update, delete: if false;
    }

    // ── Role Change Audit Log (legacy) ────────────────────────────────────────
    match /roleChangeLogs/{logId} {
      allow read:           if isAdmin();
      allow create:         if isAdmin();
      allow update, delete: if false;
    }

    // ── Admin Audit Log (unified — role, password, name, program changes) ─────
    match /adminAuditLogs/{logId} {
      allow read:           if isAdmin();
      allow create:         if isAdmin();
      allow update, delete: if false;
    }

    // ── Delete Requests (staff submits, admin approves) ───────────────────────
    match /deleteRequests/{reqId} {
      // Staff and admin can create requests
      allow create: if isStaffOrAdmin();
      // Admin can read all requests; staff can read requests they submitted
      allow read: if isAdmin() || (
        isStaffOrAdmin() &&
        resource.data.requestedBy == request.auth.uid
      );
      // Only admin can update (approve/reject)
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Books ─────────────────────────────────────────────────────────────────
    match /books/{bookId} {
      allow read:   if isSignedIn();
      allow create,
            update: if isStaffOrAdmin();
      // Delete blocked at DB level if active borrows exist for this book
      // (UI enforces this too, but rules are the hard stop)
      allow delete: if isStaffOrAdmin();
    }

    // ── Borrows ───────────────────────────────────────────────────────────────
    match /borrows/{borrowId} {
      // Students can only read their own borrow records.
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isStaffOrAdmin()
      );
      allow create: if isSignedIn() && (
        isStaffOrAdmin() ||
        (
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.status == 'pending'
        )
      );
      // Staff/admin can update any borrow.
      // Students can only cancel their own pending borrows.
      allow update: if isStaffOrAdmin() || (
        isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        resource.data.status == 'pending' &&
        request.resource.data.status == 'cancelled' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
      );
      allow delete: if isAdmin();
    }

    // ── Logger ────────────────────────────────────────────────────────────────
    match /logger/{logId} {
      // Students can only read their own log entries.
      allow read: if isSignedIn() && (
        resource.data.uid == request.auth.uid ||
        isStaffOrAdmin()
      );
      allow create: if isSignedIn() && (
        request.resource.data.uid == request.auth.uid ||
        isStaffOrAdmin()
      );
      allow update: if isSignedIn() && (
        resource.data.uid == request.auth.uid ||
        isStaffOrAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── Penalties ─────────────────────────────────────────────────────────────
    match /penalties/{penaltyId} {
      // Students can only read their own penalties.
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isStaffOrAdmin()
      );
      allow write: if isStaffOrAdmin();
    }

    // ── Email queue ───────────────────────────────────────────────────────────
    match /emailQueue/{docId} {
      allow read:           if isStaffOrAdmin();
      allow create:         if isStaffOrAdmin();
      allow update, delete: if isAdmin();
    }

    // ── Book Activity Log (catalog adds/edits/deletes) ────────────────────────
    match /bookLogs/{logId} {
      allow read:   if isStaffOrAdmin();
      allow create: if isStaffOrAdmin();
      allow update: if false;
      allow delete: if false;
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      // Students can only read their own notifications.
      allow read: if isSignedIn() && (
        resource.data.toUid == request.auth.uid ||
        isStaffOrAdmin()
      );
      allow create: if isStaffOrAdmin();

      // Staff/admin can update anything (resolve, follow up).
      // Students can only acknowledge their own notification.
      allow update: if isStaffOrAdmin() || (
        isSignedIn() &&
        resource.data.toUid == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['acknowledged', 'acknowledgedAt'])
      );

      allow delete: if isAdmin();
    }
  }
}
