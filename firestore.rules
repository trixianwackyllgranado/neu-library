rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {"role": "guest"};
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isStaffOrAdmin() {
      return isSignedIn() && (getUserData().role == 'staff' || getUserData().role == 'admin');
    }

    function isAdmin() {
      return hasRole('admin');
    }

    // Users collection
    match /users/{userId} {
      allow get: if isSignedIn() && (
        request.auth.uid == userId ||
        isStaffOrAdmin() ||
        userId.matches('invite_.*')
      );
      allow list: if isSignedIn();

      allow create: if isSignedIn() && (
        request.auth.uid == userId ||
        (isAdmin() && userId.matches('invite_.*'))
      );

      allow update: if isSignedIn() && (
        (request.auth.uid == userId &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) ||
        (isAdmin() &&
         request.auth.uid != userId &&
         resource.data.role != 'admin' &&
         (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) ||
          request.resource.data.role in ['staff', 'visitor'])) ||
        (isAdmin() && userId.matches('invite_.*')) ||
        (userId.matches('invite_.*') && isSignedIn())
      );

      allow delete: if isAdmin();
    }

    // Logger
    match /logger/{logId} {
      allow read: if isSignedIn() && (
        resource.data.uid == request.auth.uid ||
        isStaffOrAdmin()
      );
      allow create: if isSignedIn() && (
        request.resource.data.uid == request.auth.uid || isStaffOrAdmin()
      );
      allow update: if isSignedIn() && (
        resource.data.uid == request.auth.uid || isStaffOrAdmin()
      );
      allow delete: if isAdmin();
    }

    // Admin Audit Log
    match /adminAuditLogs/{logId} {
      allow read:           if isAdmin();
      allow create:         if isAdmin();
      allow update, delete: if false;
    }

    // Delete Requests
    match /deleteRequests/{reqId} {
      allow create: if isStaffOrAdmin();
      allow read:   if isAdmin() || (isStaffOrAdmin() && resource.data.requestedBy == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Notifications
    match /notifications/{notifId} {
      allow list: if isStaffOrAdmin();
      allow read: if isSignedIn() && (resource.data.toUid == request.auth.uid || isStaffOrAdmin());
      allow create: if isStaffOrAdmin();
      allow update: if isStaffOrAdmin() || (
        isSignedIn() &&
        resource.data.toUid == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['acknowledged', 'acknowledgedAt'])
      );
      allow delete: if isAdmin();
    }

    // Edit Requests
    match /editRequests/{reqId} {
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if isSignedIn() && (
        resource.data.uid == request.auth.uid ||
        isAdmin()
      );
      allow update: if isAdmin() || (
        isSignedIn() &&
        resource.data.uid == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelledAt']) &&
        request.resource.data.status == 'cancelled'
      );
      allow delete: if false;
    }

    // Staff Invites
    match /staffInvites/{inviteId} {
      allow create: if isAdmin();
      allow read:   if isSignedIn();
      allow update: if isAdmin() || (
        isSignedIn() &&
        resource.data.email == request.auth.token.email &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'claimedAt', 'claimedBy'])
      );
      allow delete: if isAdmin();
    }

    // ── Tutorial Preferences ──────────────────────────────────────────────────
    // Simple own-doc rules — NO getUserData() calls, so zero extra reads.
    match /tutorialPrefs/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // ── Online Presence ───────────────────────────────────────────────────────
    // Simple own-doc write, any signed-in user can read. NO getUserData() calls.
    match /onlinePresence/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
