rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {"role": "guest"};
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isStaffOrAdmin() {
      return isSignedIn() && (getUserData().role == 'staff' || getUserData().role == 'admin');
    }

    function isAdmin() {
      return hasRole('admin');
    }

    // Users collection
    // Note: create is open to any signed-in user (their own doc) because IT support
    // Gmail accounts and staff-invited Gmail accounts bypass the NEU email domain.
    // Domain enforcement is handled in application code (AuthContext).
    match /users/{userId} {
      allow get: if isSignedIn() && (
        request.auth.uid == userId ||
        isStaffOrAdmin() ||
        // Allow reading placeholder pre-created docs during sign-in migration
        userId.matches('invite_.*')
      );
      allow list: if isSignedIn();

      // Own registration OR admin pre-creating a placeholder profile (invite_* UID)
      allow create: if isSignedIn() && (
        request.auth.uid == userId ||
        (isAdmin() && userId.matches('invite_.*'))
      );

      allow update: if isSignedIn() && (
        // Own doc — no role changes allowed by self
        (request.auth.uid == userId &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) ||
        // Admin can change roles (not to admin, not own doc)
        (isAdmin() &&
         request.auth.uid != userId &&
         resource.data.role != 'admin' &&
         (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) ||
          request.resource.data.role in ['staff', 'visitor'])) ||
        // Admin can update placeholder docs (invite_* migration)
        (isAdmin() && userId.matches('invite_.*'))
      );

      allow delete: if isAdmin();
    }

    // Logger — visitors and staff/admin
    match /logger/{logId} {
      allow read: if isSignedIn() && (
        resource.data.uid == request.auth.uid ||
        isStaffOrAdmin()
      );
      allow create: if isSignedIn() && (
        request.resource.data.uid == request.auth.uid || isStaffOrAdmin()
      );
      allow update: if isSignedIn() && (
        resource.data.uid == request.auth.uid || isStaffOrAdmin()
      );
      allow delete: if isAdmin();
    }

    // Admin Audit Log — immutable
    match /adminAuditLogs/{logId} {
      allow read:           if isAdmin();
      allow create:         if isAdmin();
      allow update, delete: if false;
    }

    // Delete Requests
    match /deleteRequests/{reqId} {
      allow create: if isStaffOrAdmin();
      allow read:   if isAdmin() || (isStaffOrAdmin() && resource.data.requestedBy == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.toUid == request.auth.uid || isStaffOrAdmin());
      allow create: if isStaffOrAdmin();
      allow update: if isStaffOrAdmin() || (
        isSignedIn() &&
        resource.data.toUid == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['acknowledged', 'acknowledgedAt'])
      );
      allow delete: if isAdmin();
    }

    // Edit Requests — visitors submit requests to change their info;
    // only the owner can cancel their own pending request; admin approves/rejects.
    match /editRequests/{reqId} {
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if isSignedIn() && (
        resource.data.uid == request.auth.uid ||
        isAdmin()
      );
      // Visitor can only cancel their own pending request
      allow update: if isAdmin() || (
        isSignedIn() &&
        resource.data.uid == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelledAt']) &&
        request.resource.data.status == 'cancelled'
      );
      allow delete: if false;
    }

    // Staff Invites — admin creates, any signed-in user can read (to check their own invite)
    match /staffInvites/{inviteId} {
      allow create: if isAdmin();
      allow read:   if isSignedIn();
      allow update: if isAdmin() || (
        isSignedIn() &&
        resource.data.email == request.auth.token.email &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'claimedAt', 'claimedBy'])
      );
      allow delete: if isAdmin();
    }
  }
}
